{
  "name": "notebooklm-ts",
  "version": "0.1.0",
  "description": "TypeScript CLI and API for Google NotebookLM",
  "type": "module",
  "bin": {
    "notebooklm": "./src/cli/index.ts"
  },
  "scripts": {
    "start": "bun run src/cli/index.ts",
    "test": "bun test",
    "build": "bun build --compile --external chromium-bidi --external electron src/cli/index.ts --outfile notebooklm",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "ora": "^8.1.1",
    "playwright": "^1.50.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "msw": "^2.7.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
