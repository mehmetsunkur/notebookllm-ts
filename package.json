{
  "name": "notebooklm-ts",
  "version": "0.1.1",
  "description": "TypeScript CLI and API for Google NotebookLM",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli/index.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "notebooklm": "./dist/cli/index.js"
  },
  "scripts": {
    "start": "tsx src/cli/index.ts",
    "test": "vitest run",
    "build": "tsup src/cli/index.ts src/index.ts --format esm --dts --out-dir dist",
    "prepare": "tsup src/cli/index.ts src/index.ts --format esm --dts --out-dir dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "ora": "^8.1.1",
    "playwright": "^1.50.1"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7"
  }
}
